{
  "name": "joshh-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "audit:secrets": "gitleaks detect --no-git --source . --config .gitleaks.toml --no-banner --redact",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "check": "npm run audit:secrets && npm run audit:deps && npm run typecheck && npm run lint && npm run test",
    "check:bundle": "node scripts/check-bundle.mjs",
    "infra:check": "npm --prefix infra run check",
    "infra:synth": "npm --prefix infra run cdk:synth",
    "setup:hooks": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit"
  },
  "dependencies": {
    "@fontsource-variable/cormorant-garamond": "^5.2.8",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^6.0.0",
    "happy-dom": "^20.11.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
